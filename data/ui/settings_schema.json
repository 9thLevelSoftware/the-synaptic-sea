{
  "version": "settings-state-1",
  "schema": "settings-state-1",
  "fields": {
    "text_scale":       { "type": "float",  "min": 1.0, "max": 2.0, "default": 1.0 },
    "colorblind_mode":  { "type": "enum",   "values": ["none", "protanopia", "deuteranopia", "tritanopia"], "default": "none" },
    "motion_reduce":    { "type": "bool",   "default": false },
    "captions":         { "type": "bool",   "default": true },
    "hold_to_tap":      { "type": "bool",   "default": false },
    "difficulty":       { "type": "enum",   "values": ["standard", "hardened", "deep_dive"], "default": "standard" },
    "glyph_scheme":     { "type": "enum",   "values": ["auto", "keyboard", "gamepad_xbox", "gamepad_ps"], "default": "auto" },
    "preset_id":        { "type": "string", "default": "default" }
  }
}